{
  "compilerOptions": {
    "target": "es6",                    // Modern JS output
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,                     // Allows JS files too
    "skipLibCheck": true,                // Skip type checking for node_modules
    "strict": true,                      // Enable strict type checking
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,                      // Don't output compiled files (Next.js handles this)
    "esModuleInterop": true,             // Allow default imports from CommonJS modules
    "module": "esnext",
    "moduleResolution": "node",          // Find node_modules packages
    "resolveJsonModule": true,           // Allow importing JSON files
    "isolatedModules": true,
    "jsx": "preserve"                    // Keep JSX for Next.js
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
 